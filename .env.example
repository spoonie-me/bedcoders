# ──────────────────────────────────────────
# DATABASE & ORM
# ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bedcoders
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# ──────────────────────────────────────────
# AUTHENTICATION
# ──────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=30d
BCRYPT_ROUNDS=10
EMAIL_VERIFICATION_REQUIRED=true

# ──────────────────────────────────────────
# CLAUDE API (AI Feedback)
# ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# ──────────────────────────────────────────
# PAYMENTS (Stripe)
# ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Bedcoders subscription pricing (created in Stripe Dashboard)
# Pro Monthly: €12/month (recurring)
STRIPE_PRICE_ID_PRO_MONTHLY=price_1TDPgHABG63Fjch4fTTlLldN
# Pro Annual: €120/year (recurring, saves €24)
STRIPE_PRICE_ID_PRO_ANNUAL=price_1TDPgIABG63Fjch44n1GjdNp
# Team Seat: €15/user/month (recurring, min 5 seats)
STRIPE_PRICE_ID_TEAM_SEAT=price_1TDPgJABG63Fjch4zA4sDRR5

# Webhook events to register in Stripe Dashboard:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_succeeded
#   invoice.payment_failed

# ──────────────────────────────────────────
# EMAIL (Resend)
# ──────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@bedcoders.com
RESEND_FROM_NAME=Bedcoders

# ──────────────────────────────────────────
# ANALYTICS (PostHog)
# ──────────────────────────────────────────
POSTHOG_API_KEY=phc_...
POSTHOG_API_URL=https://eu.posthog.com
POSTHOG_ENABLED=true

# ──────────────────────────────────────────
# APP CONFIGURATION
# ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000

# ──────────────────────────────────────────
# LEGAL & COMPLIANCE
# ──────────────────────────────────────────
COMPANY_NAME=Bedcoders
COMPANY_ADDRESS=Vienna, Austria
COMPANY_EMAIL=legal@bedcoders.com
GDPR_DATA_RETENTION_DAYS=2555
AUDIT_LOG_RETENTION_DAYS=1095
DATA_DELETION_GRACE_PERIOD_DAYS=30

# ──────────────────────────────────────────
# SECURITY
# ──────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
